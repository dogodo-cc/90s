{
  "name": "90s-ui",
  "version": "0.0.12",
  "description": "个人的组件库，只为更好的管理业务上通用的组件",
  "main": "lib/hello-ui.js",
  "style": "lib/hello-ui.css",
  "author": "alan",
  "license": "MIT",
  "private": false,
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "dev": "webpack-dev-server --config ./build/webpack.dev.js",
    "build": "webpack --config ./build/webpack.prod.js",
    "prebuild": "npm run deploy",
    "build:css": "gulp build --gulpfile ./build/gulpfile.js",
    "deploy": "npm run build:css && webpack --config ./build/webpack.component.js",
    "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml"
  },
  "homepage": "https://www.90s.co/ui",
