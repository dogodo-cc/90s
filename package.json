{
  "name": "90s",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "走在前端的大道上",
  "author": "alan",
  "scripts": {
    "build:90s": "lerna exec --scope @90s/web -- npm run build",
    "start:90s": "lerna exec --scope @90s/web -- npm run start",
    "release:90s": "lerna exec --scope @90s/web -- npm run release"
  },
  "devDependencies": {
    "@commitlint/cli": "^8.1.0",
    "@commitlint/config-conventional": "^8.1.0",
    "commitizen": "^4.0.3",
    "cz-customizable": "^6.2.0",
    "eslint": "^5.0.0",
    "eslint-plugin-vue": "^5.2.3",
    "husky": "^3.0.4",
    "lerna": "^3.16.4",
    "lint-staged": "^9.2.3"
  },
  "bugs": {
    "url": "https://github.com/dogodo-cc/on-the-way/issues"
  },
  "keywords": [],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogodo-cc/on-the-way.git"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable",
      "defaultType": "feat"
    },
    "cz-customizable": {
      "config": "./.cz-config.js"
    }
  },
  "lint-staged": {
    "packages/**/*.{js,vue,ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  }
}
