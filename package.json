{
  "name": "on-the-way",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "走在前端的大道上",
  "author": "alan",
  "scripts": {
    "build:90s": "cd packages/90s && NODE_ENV=production webpack --config ./build/webpack.prod.js",
    "lint": "eslint --ext .js,.vue packages",
    "start:90s": "cd packages/90s && webpack-dev-server --config ./build/webpack.dev.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^8.1.0",
    "@commitlint/config-conventional": "^8.1.0",
    "commitizen": "^4.0.3",
    "cz-customizable": "^6.2.0",
    "eslint": "^5.0.0",
    "eslint-plugin-vue": "^5.2.3",
    "husky": "^3.0.4",
    "lerna": "^3.16.4"
  },
  "bugs": {
    "url": "https://github.com/dogodo-cc/on-the-way/issues"
  },
  "keywords": [],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogodo-cc/on-the-way.git"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable",
      "defaultType": "feat"
    },
    "cz-customizable": {
      "config": "./.cz-config.js"
    }
  }
}
