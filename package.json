{
  "name": "on-the-way",
  "version": "1.0.0",
  "private": true,
  "description": "走在前端的大道上",
  "author": "alan",
  "scripts": {
    "build": "NODE_ENV=production webpack --config ./build/webpack.prod.js",
    "lint": "eslint --ext .js,.vue src",
    "start": "webpack-dev-server --config ./build/webpack.dev.js",
    "case": "node create-case-list.js"
  },
  "dependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.2.0",
    "@babel/polyfill": "^7.4.4",
    "@babel/runtime-corejs2": "^7.4.5",
    "@tweenjs/tween.js": "^17.4.0",
    "animejs": "^3.0.1",
    "core-js": "^3.1.4",
    "element-ui": "^2.10.1",
    "jquery": "^3.4.1",
    "normalize.css": "^8.0.1",
    "three": "^0.106.2",
    "vue": "^2.6.10",
    "vue-router": "^3.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.4.5",
    "@babel/plugin-transform-runtime": "^7.4.4",
    "@babel/preset-env": "^7.4.5",
    "@commitlint/cli": "^8.1.0",
    "@commitlint/config-conventional": "^8.1.0",
    "babel-eslint": "^10.0.2",
    "babel-loader": "^8.0.6",
    "babel-plugin-component": "^1.1.1",
    "clean-webpack-plugin": "^3.0.0",
    "commitizen": "^4.0.3",
    "css-loader": "^3.0.0",
    "cssnano": "^4.1.10",
    "cz-conventional-changelog": "^3.0.2",
    "cz-customizable": "^6.2.0",
    "eslint": "^5.0.0",
    "eslint-plugin-vue": "^5.2.3",
    "file-loader": "^4.0.0",
    "html-webpack-plugin": "^3.2.0",
    "husky": "^3.0.4",
    "node-sass": "^4.12.0",
    "postcss": "^7.0.17",
    "postcss-cssnext": "^3.1.0",
    "postcss-import": "^12.0.1",
    "postcss-inline-svg": "^4.1.0",
    "postcss-loader": "^3.0.0",
    "sass-loader": "^7.1.0",
    "style-loader": "^0.23.1",
    "sugarss": "^2.0.0",
    "uglifyjs-webpack-plugin": "^2.1.3",
    "url-loader": "^2.1.0",
    "vue-loader": "^15.7.0",
    "vue-template-compiler": "^2.6.10",
    "webpack": "^4.35.0",
    "webpack-cli": "^3.3.5",
    "webpack-dev-server": "^3.7.2",
    "webpack-manifest-plugin": "^2.0.4",
    "webpack-merge": "^4.2.1"
  },
  "bugs": {
    "url": "https://github.com/dogodo-cc/on-the-way/issues"
  },
  "homepage": "https://www.90s.co",
  "keywords": [],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogodo-cc/on-the-way.git"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable",
      "defaultType": "feat"
    },
    "cz-customizable": {
      "config": "./.cz-config.js"
    }
  }
}
